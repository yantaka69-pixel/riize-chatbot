# RIIZE Chat Server Configuration
# 复制此文件为 .env 并填入你的配置

# 服务器端口
PORT=3001

# 数据库路径（SQLite文件）
DATABASE_PATH=./data/riize-chat.db

# 上传文件存储目录
UPLOAD_DIR=./data/uploads

# 前端静态文件路径（生产模式，留空则自动检测）
# FRONTEND_DIST_PATH=./client/dist

# ============================================
# AI API 配置 — 支持 OpenAI 兼容接口
# ============================================
# 推荐方案（按质量排序）：
#
# 【1】DeepSeek — 注册送 $52 免费额度，中文质量最好
#   注册地址：https://platform.deepseek.com
#   OPENAI_API_KEY=sk-你从DeepSeek获取的key
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat
#
# 【2】硅基流动 SiliconFlow — 完全免费模型，不限额度（有速率限制）
#   注册地址：https://cloud.siliconflow.cn
#   OPENAI_API_KEY=sk-你从SiliconFlow获取的key
#   OPENAI_BASE_URL=https://api.siliconflow.cn/v1
#   OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# 【3】智谱清言 — GLM-4-Flash 完全免费
#   注册地址：https://open.bigmodel.cn
#   OPENAI_API_KEY=你从智谱获取的key
#   OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   OPENAI_MODEL=glm-4-flash
#
# ============================================

OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct

# 设置页管理密码（默认 admin123，可在设置页修改）
ADMIN_PASSWORD=admin123
